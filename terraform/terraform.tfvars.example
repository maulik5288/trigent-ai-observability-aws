aws_region          = "ap-south-1"
project_name        = "ai-observability-test"
instance_type       = "t3.large"
root_volume_size_gb = 60

# REQUIRED: lock access down to your own IP (find it: curl ifconfig.me)
allowed_cidr_blocks = ["YOUR.PUBLIC.IP.ADDRESS/32"]

# Optional: existing EC2 key pair name for SSH (needed to read generated credentials)
key_name = "my-keypair"
